{
  "manifest_version": 3,
  "name": "User Manual Recorder",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "storage","downloads","tabs"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}